# Simco Intel Backend Configuration
# Copy to .env and fill in values.

# Simco Tools API realms (comma-separated, e.g. "0" or "0,1")
# 0 = Magnates, 1 = Entrepreneurs
SIMCO_REALMS=0

# Path to data repo checkout (public data repo for snapshots)
DATA_REPO_PATH=../Data

# GitHub personal access token for writing to data repo
GITHUB_TOKEN=

# Data repo identity (used for commit authorship)
DATA_REPO_OWNER=
DATA_REPO_NAME=SimcoIntel
DATA_REPO_BRANCH=main

# Discord webhook URL for failure alerts
ALERT_WEBHOOK_URL=

# HTTP server port for backend-ui
HTTP_PORT=3001

# Log level: debug | info | warn | error
LOG_LEVEL=info
